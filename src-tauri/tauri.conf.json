{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "inD3X Art",
  "version": "0.3.5",
  "identifier": "com.ind3x.art",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "inD3X Art",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["mica"],
          "state": "followsWindowActiveState"
        },
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost blob: data:; style-src 'self'; style-src-attr 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "inD3X",
    "copyright": "Copyright © 2026 inD3X",
    "category": "DeveloperTool",
    "shortDescription": "Premium Minecraft asset editor",
    "longDescription": "inD3X Art indexes Minecraft mods and resource packs, previews block models in 3D, and edits textures with a pixel-art workflow.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false,
        "files": {}
      },
      "deb": {
        "depends": [],
        "files": {}
      }
    },
    "windows": {
      "wix": {
        "language": ["en-US", "ru-RU"]
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "Russian"],
        "displayLanguageSelector": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
